<section class="search-page"><div class="center-logo"><img src="<%= settings.logoUrl %>" alt="<%= settings.siteName %>"><h1><%= settings.siteName %> Search</h1></div><form class="searchbox big" action="/search" method="get"><input name="q" value="<%= q || '' %>" placeholder="Ketik kata kunci..." autofocus><button>Cari</button></form><div class="chips center"><% trending.forEach(t=>{ %><a href="/search/<%= encodeURIComponent(t.toLowerCase().replace(/\s+/g,'-')) %>"><%= t %></a><% }) %></div><div class="results"><% if(q && results.length===0){ %><div class="empty">Belum ada hasil untuk <b><%= q %></b>. Tambahkan data dari admin agar hasil muncul.</div><% } %><% results.forEach(r=>{ %><article class="result"><span><%= r.type %></span><h2><a href="<%= r.url %>"><%= r.title %></a></h2><p><%= r.description %></p><small><%= r.url %></small></article><% }) %></div></section>
