<section class="search-page">

  <div class="center-logo">

    <img
      src="<%= settings.logoUrl %>"
      alt="<%= settings.siteName %>"
      loading="eager"
    >

    <h1>
      <%= settings.siteName %> Search
    </h1>

    <p>
      Temukan berbagai informasi terbaru, berita pilihan, update aplikasi, jadwal pertandingan, dan halaman populer melalui sistem pencarian yang cepat dan nyaman digunakan.
    </p>

  </div>

  <form
    class="searchbox big"
    action="/search"
    method="get"
  >

    <input
      name="q"
      value="<%= q || '' %>"
      placeholder="Cari informasi, artikel, atau halaman lainnya..."
      autocomplete="off"
      autofocus
    >

    <button>
      Cari
    </button>

  </form>

  <div class="chips center">

    <% trending.forEach(t=>{ %>

      <a href="/search/<%= encodeURIComponent(t.toLowerCase().replace(/\s+/g,'-')) %>">

        <%= t %>

      </a>

    <% }) %>

  </div>

  <div class="results">

    <% if(q && results.length === 0){ %>

      <div class="empty">

        Informasi untuk
        <b>
          <%= q %>
        </b>
        belum tersedia atau sedang diperbarui.

      </div>

    <% } %>

    <% results.forEach(r=>{ %>

      <article class="result">

        <span>
          <%= r.type %>
        </span>

        <h2>

          <a href="<%= r.url %>">

            <%= r.title %>

          </a>

        </h2>

        <p>
          <%= r.description %>
        </p>

        <small>
          <%= r.url %>
        </small>

      </article>

    <% }) %>

  </div>

</section>
