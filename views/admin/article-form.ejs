<div class="head"><div><span>EDITOR</span><h1><%= article ? 'Edit Artikel' : 'Tambah Artikel' %></h1></div></div><form class="panel form" method="post" action="<%= article ? adminPath + '/articles/' + article.id : adminPath + '/articles' %>"><label>Judul<input name="title" value="<%= article ? article.title : '' %>" required></label><label>Slug<input name="slug" value="<%= article ? article.slug : '' %>" placeholder="otomatis jika kosong"></label><label>Kategori<input name="category" value="<%= article ? article.category : 'Berita Bola' %>"></label><label>Author<input name="author" value="<%= article ? article.author : 'Redaksi' %>"></label><label>Cover URL<input name="coverUrl" value="<%= article ? article.coverUrl : '/images/default-cover.svg' %>"></label><label>Excerpt<textarea name="excerpt"><%= article ? article.excerpt : '' %></textarea></label><label>Konten HTML<textarea name="content" rows="12"><%= article ? article.content : '' %></textarea></label><label>Tags koma<input name="tags" value="<%= article ? (article.tags||[]).join(', ') : '' %>"></label><label>Status<select name="status"><option value="published" <%= article && article.status==='published'?'selected':'' %>>published</option><option value="draft" <%= article && article.status==='draft'?'selected':'' %>>draft</option></select></label><button>Simpan Artikel</button></form>
