<div class="head"><div><span>APK</span><h1>Pengaturan Aplikasi</h1></div></div><form class="panel form" method="post"><label>Version<input name="version" value="<%= apk.version %>"></label><label>Android URL<input name="androidUrl" value="<%= apk.androidUrl %>"></label><label>Changelog satu baris per item<textarea name="changelog" rows="8"><%= (apk.changelog||[]).join('\n') %></textarea></label><button>Simpan APK</button></form>
