<div class="head"><div><span>WEBSITE</span><h1>Pengaturan Website</h1></div></div><form class="panel form" method="post"><label>Site Name<input name="siteName" value="<%= settings.siteName %>"></label><label>Tagline<input name="siteTagline" value="<%= settings.siteTagline %>"></label><label>Description<textarea name="siteDescription"><%= settings.siteDescription %></textarea></label><label>Base URL<input name="baseUrl" value="<%= settings.baseUrl || '' %>" placeholder="https://domain.com"></label><label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl %>"></label><label>Favicon URL<input name="faviconUrl" value="<%= settings.faviconUrl %>"></label><label>Hero Title<input name="heroTitle" value="<%= settings.heroTitle %>"></label><label>Hero Subtitle<textarea name="heroSubtitle"><%= settings.heroSubtitle %></textarea></label><label>Admin Path<input name="adminPath" value="<%= settings.adminPath %>"></label><label>Login URL<input name="loginUrl" value="<%= settings.loginUrl %>"></label><label>Daftar URL<input name="daftarUrl" value="<%= settings.daftarUrl %>"></label><label>Livechat URL<input name="livechatUrl" value="<%= settings.livechatUrl %>"></label><label>Whatsapp URL<input name="whatsappUrl" value="<%= settings.whatsappUrl %>"></label><label>Ticker Text<input name="tickerText" value="<%= settings.tickerText %>"></label><label>Footer Text<textarea name="footerText"><%= settings.footerText %></textarea></label><button>Simpan Pengaturan</button></form>
