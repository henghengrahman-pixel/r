<!doctype html>

<html lang="id">

<head>

  <meta charset="utf-8">

  <meta
    name="viewport"
    content="width=device-width,initial-scale=1"
  >

  <title>
    Login Admin | OMTOGEL
  </title>

  <meta
    name="robots"
    content="noindex,nofollow"
  >

  <meta
    name="theme-color"
    content="#050505"
  >

  <link
    rel="stylesheet"
    href="/css/admin.css"
  >

</head>

<body class="login-page">

  <div class="login-overlay"></div>

  <form
    class="login-card"
    method="post"
    action="/pinktiger8008/login"
    autocomplete="off"
  >

    <div class="login-head">

      <h1>
        Admin Panel
      </h1>

      <p>
        SEO ECEK ECEK AJA
      </p>

    </div>

    <% if(error && error.length){ %>

      <div class="alert error">

        <%= error[0] %>

      </div>

    <% } %>

    <% if(success && success.length){ %>

      <div class="alert success">

        <%= success[0] %>

      </div>

    <% } %>

    <div class="form-group">

      <label>
        Admin ID
      </label>

      <input
        type="text"
        name="username"
        placeholder="Masukkan admin ID"
        required
      >

    </div>

    <div class="form-group">

      <label>
        Password
      </label>

      <input
        type="password"
        name="password"
        placeholder="Masukkan password"
        required
      >

    </div>

    <button type="submit">

      Login Admin

    </button>

    <small>
      PINK TIGER.
    </small>

  </form>

</body>

</html>
