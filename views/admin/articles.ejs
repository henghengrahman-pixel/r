<div class="head"><div><span>KONTEN</span><h1>Artikel</h1></div><a class="btn" href="<%= adminPath %>/articles/new">Tambah Artikel</a></div><div class="panel"><table><thead><tr><th>Judul</th><th>Kategori</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% articles.forEach(a=>{ %><tr><td><%= a.title %><br><small>/berita/<%= a.slug %></small></td><td><%= a.category %></td><td><%= a.status %></td><td><a href="<%= adminPath %>/articles/<%= a.id %>/edit">Edit</a><form method="post" action="<%= adminPath %>/articles/<%= a.id %>/delete" style="display:inline"><button class="danger">Hapus</button></form></td></tr><% }) %></tbody></table></div>
