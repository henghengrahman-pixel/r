<div class="head"><div><span>SEARCH</span><h1>Data Pencarian</h1></div></div><form class="panel form" method="post"><label>Title<input name="title" required></label><label>URL<input name="url" placeholder="/apk" required></label><label>Type<input name="type" value="Brand"></label><label>Description<textarea name="description"></textarea></label><label>Keywords koma<input name="keywords"></label><label>Priority<input name="priority" type="number" value="5"></label><label>Trending Search koma<textarea name="trending"><%= trending.join(', ') %></textarea></label><button>Tambah & Simpan</button></form><div class="panel"><table><% items.forEach(i=>{ %><tr><td><b><%= i.title %></b><br><small><%= i.url %></small></td><td><%= i.type %></td><td><form method="post" action="<%= adminPath %>/search-data/<%= i.id %>/delete"><button class="danger">Hapus</button></form></td></tr><% }) %></table></div>
