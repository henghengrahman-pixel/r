<section class="hero">

  <div class="hero-overlay"></div>

  <div class="hero-copy">

    <div class="hero-top">

      <span class="badge">
        PORTAL RESMI OMTOGEL
      </span>

      <div class="hero-live">

        <span class="dot"></span>

        LIVE UPDATE 24 JAM

      </div>

    </div>

    <h1>
      <%= settings.heroTitle || 'OMTOGEL Portal Berita Bola dan Live Score Realtime' %>
    </h1>

    <p class="hero-desc">

      OMTOGEL menghadirkan berita bola terbaru, live score realtime,
      prediksi pertandingan, jadwal bola malam ini, transfer pemain,
      statistik pertandingan, dan berbagai informasi sepak bola dunia
      dalam tampilan modern yang cepat, ringan, dan mobile friendly.

    </p>

    <form
      class="searchbox"
      action="/search"
      method="get"
    >

      <input
        type="text"
        name="q"
        placeholder="Cari berita bola, live score, jadwal pertandingan..."
        autocomplete="off"
      >

      <button type="submit">
        Cari
      </button>

    </form>

    <div class="quick">

      <a
        class="red"
        href="<%= settings.daftarUrl %>"
      >
        Daftar
      </a>

      <a href="<%= settings.loginUrl %>">
        Login
      </a>

      <a href="/berita">
        Berita Bola
      </a>

      <a href="/apk">
        Download APK
      </a>

      <a href="/p/omtogel">
        Tentang
      </a>

    </div>

    <div class="hero-seo">

      <div class="seo-item">

        <strong>
          Berita Bola Hari Ini
        </strong>

        <span>
          Informasi sepak bola terbaru setiap hari
        </span>

      </div>

      <div class="seo-item">

        <strong>
          Live Score Realtime
        </strong>

        <span>
          Update skor pertandingan realtime
        </span>

      </div>

      <div class="seo-item">

        <strong>
          Prediksi Bola Terbaru
        </strong>

        <span>
          Analisa pertandingan dan prediksi skor
        </span>

      </div>

      <div class="seo-item">

        <strong>
          Jadwal Bola Malam Ini
        </strong>

        <span>
          Jadwal pertandingan liga dunia terbaru
        </span>

      </div>

    </div>

  </div>

  <aside class="hero-card">

    <div class="card-top">

      <span>
        TRENDING SEARCH
      </span>

      <h3>
        Pencarian Populer
      </h3>

      <p>
        Keyword dan topik yang sedang banyak dicari pengunjung hari ini.
      </p>

    </div>

    <div class="chips">

      <% trending.forEach(t => { %>

        <a
          href="/search/<%= encodeURIComponent(
            t.toLowerCase().replace(/\s+/g,'-')
          ) %>"
        >
          <%= t %>
        </a>

      <% }) %>

    </div>

    <div class="hero-info">

      <div class="info-box">

        <strong>
          Live Update
        </strong>

        <span>
          Berita bola terbaru dan live score realtime setiap hari.
        </span>

      </div>

      <div class="info-box">

        <strong>
          Mobile Friendly
        </strong>

        <span>
          Tampilan ringan dan responsif di semua perangkat.
        </span>

      </div>

      <div class="info-box">

        <strong>
          Portal Modern
        </strong>

        <span>
          Informasi cepat, akurat, dan nyaman dibaca kapan saja.
        </span>

      </div>

    </div>

  </aside>

</section>

<section class="section latest-section">

  <div class="section-head">

    <div>

      <span>
        UPDATE TERBARU
      </span>

      <h2>
        Berita Bola dan Informasi Pilihan
      </h2>

      <p>
        Update sepak bola dunia, transfer pemain, jadwal pertandingan,
        live score, dan berita olahraga terbaru.
      </p>

    </div>

    <a
      class="view-all"
      href="/berita"
    >
      Lihat Semua
    </a>

  </div>

  <div class="grid cards">

    <% articles.forEach(a => { %>

      <article class="card">

        <a
          class="thumb"
          href="/berita/<%= a.slug %>"
        >

          <img
            src="<%= a.coverUrl %>"
            alt="<%= a.title %>"
            loading="lazy"
          >

        </a>

        <div class="card-body">

          <span class="cat">
            <%= a.category %>
          </span>

          <h3>

            <a href="/berita/<%= a.slug %>">
              <%= a.title %>
            </a>

          </h3>

          <p>
            <%= a.excerpt %>
          </p>

          <div class="card-meta">

            <span>
              OMTOGEL
            </span>

            <a href="/berita/<%= a.slug %>">
              Baca →
            </a>

          </div>

        </div>

      </article>

    <% }) %>

  </div>

</section>

<section class="seo-panel">

  <div class="seo-content">

    <span>
      PORTAL INFORMASI MODERN
    </span>

    <h2>
      OMTOGEL Live Score, Berita Bola, dan Prediksi Bola Terbaru
    </h2>

    <p>

      OMTOGEL menghadirkan berbagai informasi sepak bola terbaru mulai dari
      live score realtime, jadwal pertandingan malam ini, berita transfer pemain,
      prediksi skor pertandingan, hingga update kompetisi dunia dalam satu
      portal modern yang cepat, ringan, dan nyaman diakses melalui perangkat mobile.

    </p>

    <div class="seo-links">

      <a href="/">
        OMTOGEL
      </a>

      <a href="/berita">
        Berita Bola
      </a>

      <a href="/p/omtogel">
        Portal OMTOGEL
      </a>

      <a href="/search/live-score">
        Live Score
      </a>

      <a href="/search/prediksi-bola">
        Prediksi Bola
      </a>

      <a href="/search/jadwal-bola">
        Jadwal Bola
      </a>

    </div>

  </div>

</section>
