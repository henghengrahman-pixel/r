<section class="hero">

  <div class="hero-overlay"></div>

  <div class="hero-copy">

    <span class="badge">
      PORTAL RESMI OMTOGEL
    </span>

    <h1>
      <%= settings.heroTitle || 'OMTOGEL' %>
    </h1>

    <p class="hero-desc">

      OMTOGEL menghadirkan berita bola terbaru, live score realtime,
      prediksi pertandingan, jadwal bola malam ini, update transfer pemain,
      hingga informasi portal modern yang cepat, ringan, dan mobile friendly.

    </p>

    <form
      class="searchbox"
      action="/search"
      method="get"
    >

      <input
        type="text"
        name="q"
        placeholder="Cari berita bola, live score, jadwal pertandingan..."
        autocomplete="off"
      >

      <button type="submit">
        Cari
      </button>

    </form>

    <div class="quick">

      <a
        class="red"
        href="<%= settings.daftarUrl %>"
      >
        Daftar
      </a>

      <a href="<%= settings.loginUrl %>">
        Login
      </a>

      <a href="/berita">
        Berita Bola
      </a>

      <a href="/apk">
        APK
      </a>

      <a href="/p/omtogel">
        Tentang
      </a>

    </div>

    <div class="hero-seo">

      <h2>
        Berita Bola Hari Ini
      </h2>

      <h2>
        Live Score Realtime
      </h2>

      <h2>
        Prediksi Bola Terbaru
      </h2>

      <h2>
        Jadwal Bola Malam Ini
      </h2>

    </div>

  </div>

  <div class="hero-card">

    <div class="card-top">

      <span>
        Trending Search
      </span>

      <h3>
        Pencarian Populer
      </h3>

    </div>

    <div class="chips">

      <% trending.forEach(t => { %>

        <a
          href="/search/<%= encodeURIComponent(
            t.toLowerCase().replace(/\s+/g,'-')
          ) %>"
        >
          <%= t %>
        </a>

      <% }) %>

    </div>

    <div class="hero-info">

      <div>

        <strong>
          Live Update
        </strong>

        <span>
          Berita bola dan live score realtime
        </span>

      </div>

      <div>

        <strong>
          Mobile Friendly
        </strong>

        <span>
          Tampilan cepat dan ringan semua perangkat
        </span>

      </div>

    </div>

  </div>

</section>

<section class="section latest-section">

  <div class="section-head">

    <div>

      <span>
        UPDATE TERBARU
      </span>

      <h2>
        Berita Bola dan Informasi Pilihan
      </h2>

    </div>

    <a
      class="view-all"
      href="/berita"
    >
      Lihat Semua
    </a>

  </div>

  <div class="grid cards">

    <% articles.forEach(a => { %>

      <article class="card">

        <a
          class="thumb"
          href="/berita/<%= a.slug %>"
        >

          <img
            src="<%= a.coverUrl %>"
            alt="<%= a.title %>"
            loading="lazy"
          >

        </a>

        <div class="card-body">

          <span class="cat">
            <%= a.category %>
          </span>

          <h3>

            <a href="/berita/<%= a.slug %>">
              <%= a.title %>
            </a>

          </h3>

          <p>
            <%= a.excerpt %>
          </p>

          <div class="card-meta">

            <span>
              OMTOGEL
            </span>

            <a href="/berita/<%= a.slug %>">
              Baca →
            </a>

          </div>

        </div>

      </article>

    <% }) %>

  </div>

</section>

<section class="seo-panel">

  <div class="seo-content">

    <span>
      PORTAL INFORMASI MODERN
    </span>

    <h2>
      OMTOGEL Live Score, Berita Bola, dan Prediksi Pertandingan Terbaru
    </h2>

    <p>

      OMTOGEL menghadirkan berbagai informasi sepak bola terbaru mulai dari
      live score realtime, berita transfer pemain, jadwal pertandingan malam ini,
      prediksi skor, hingga update kompetisi dunia dalam satu portal modern
      yang cepat, ringan, dan nyaman diakses melalui perangkat mobile.

    </p>

    <div class="seo-links">

      <a href="/">
        OMTOGEL
      </a>

      <a href="/berita">
        Berita Bola
      </a>

      <a href="/p/omtogel">
        Portal OMTOGEL
      </a>

      <a href="/search/live-score">
        Live Score
      </a>

    </div>

  </div>

</section>
