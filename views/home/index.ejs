<section class="hero"><div class="hero-copy"><span class="badge">PORTAL BRAND</span><h1><%= settings.heroTitle %></h1><p><%= settings.heroSubtitle %></p><form class="searchbox" action="/search" method="get"><input name="q" placeholder="Cari artikel, APK, prediksi, atau halaman brand..." autocomplete="off"><button>Cari</button></form><div class="quick"><a class="red" href="<%= settings.daftarUrl %>">Daftar</a><a href="<%= settings.loginUrl %>">Login</a><a href="/berita">Berita Bola</a><a href="/apk">APK</a></div></div><div class="hero-card"><h3>Trending</h3><div class="chips"><% trending.forEach(t=>{ %><a href="/search/<%= encodeURIComponent(t.toLowerCase().replace(/\s+/g,'-')) %>"><%= t %></a><% }) %></div></div></section><section class="section"><div class="section-head"><span>UPDATE</span><h2>Artikel Terbaru</h2></div><div class="grid cards"><% articles.forEach(a=>{ %><article class="card"><img src="<%= a.coverUrl %>" alt="<%= a.title %>"><div><span class="cat"><%= a.category %></span><h3><a href="/berita/<%= a.slug %>"><%= a.title %></a></h3><p><%= a.excerpt %></p></div></article><% }) %></div></section><section class="seo-panel"><h2>Portal Cepat, Rapi, dan Terstruktur</h2><p>Semua halaman disusun dengan title, meta description, canonical, sitemap, robots, dan internal link agar mudah dibaca pengguna serta mesin pencari.</p></section>
