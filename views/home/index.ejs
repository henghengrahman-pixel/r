<section class="hero">

  <div class="hero-copy">

    <span class="badge">PORTAL TERBARU</span>

    <h1>
      <%= settings.heroTitle %>
    </h1>

    <p>
      Temukan informasi terbaru, update pertandingan, akses aplikasi, berita pilihan, dan berbagai halaman populer dalam satu portal yang cepat, ringan, dan nyaman digunakan di semua perangkat.
    </p>

    <form
      class="searchbox"
      action="/search"
      method="get"
    >
      <input
        name="q"
        placeholder="Cari berita, pertandingan, aplikasi, atau halaman populer..."
        autocomplete="off"
      >

      <button>
        Cari
      </button>
    </form>

    <div class="quick">

      <a
        class="red"
        href="<%= settings.daftarUrl %>"
      >
        Daftar
      </a>

      <a href="<%= settings.loginUrl %>">
        Login
      </a>

      <a href="/berita">
        Berita Bola
      </a>

      <a href="/apk">
        APK
      </a>

    </div>

  </div>

  <div class="hero-card">

    <h3>
      Pencarian Populer
    </h3>

    <div class="chips">

      <% trending.forEach(t=>{ %>

        <a href="/search/<%= encodeURIComponent(t.toLowerCase().replace(/\s+/g,'-')) %>">
          <%= t %>
        </a>

      <% }) %>

    </div>

  </div>

</section>

<section class="section">

  <div class="section-head">

    <span>UPDATE TERBARU</span>

    <h2>
      Informasi dan Artikel Pilihan
    </h2>

  </div>

  <div class="grid cards">

    <% articles.forEach(a=>{ %>

      <article class="card">

        <img
          src="<%= a.coverUrl %>"
          alt="<%= a.title %>"
          loading="lazy"
        >

        <div>

          <span class="cat">
            <%= a.category %>
          </span>

          <h3>
            <a href="/berita/<%= a.slug %>">
              <%= a.title %>
            </a>
          </h3>

          <p>
            <%= a.excerpt %>
          </p>

        </div>

      </article>

    <% }) %>

  </div>

</section>

<section class="seo-panel">

  <h2>
    Akses Informasi Lebih Cepat dan Nyaman
  </h2>

  <p>
    Jelajahi berbagai informasi terbaru mulai dari berita olahraga, jadwal pertandingan, update aplikasi, hingga halaman populer dengan tampilan modern yang ringan, responsif, dan mudah diakses kapan saja.
  </p>

</section>
