<title><%= typeof title !== 'undefined' ? title : (settings.siteName || 'OMTOGEL') %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : (settings.siteDescription || '') %>">
<meta name="keywords" content="<%= typeof keywords !== 'undefined' ? keywords : (settings.siteKeywords || '') %>">
<meta name="robots" content="<%= typeof robots !== 'undefined' ? robots : 'index,follow,max-image-preview:large' %>">
<meta name="googlebot" content="<%= typeof robots !== 'undefined' ? robots : 'index,follow,max-image-preview:large' %>">
<meta name="author" content="<%= typeof author !== 'undefined' ? author : (settings.siteName || 'OMTOGEL') %>">
<meta name="revisit-after" content="1 days">
<link rel="canonical" href="<%= typeof canonical !== 'undefined' ? canonical : (baseUrl + currentPath) %>">
<link rel="icon" href="<%= settings.faviconUrl || '/images/favicon.svg' %>">
<link rel="apple-touch-icon" href="<%= settings.logoUrl || '/images/logo.svg' %>">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" href="/css/style.css" as="style">
<link rel="stylesheet" href="/css/style.css">
<meta property="og:type" content="<%= typeof type !== 'undefined' ? type : 'website' %>">
<meta property="og:site_name" content="<%= settings.siteName || 'OMTOGEL' %>">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : (settings.siteName || 'OMTOGEL') %>">
<meta property="og:description" content="<%= typeof description !== 'undefined' ? description : (settings.siteDescription || '') %>">
<meta property="og:url" content="<%= typeof canonical !== 'undefined' ? canonical : (baseUrl + currentPath) %>">
<meta property="og:image" content="<%= typeof image !== 'undefined' ? image : (settings.logoUrl || '/images/logo.svg') %>">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : (settings.siteName || 'OMTOGEL') %>">
<meta name="twitter:description" content="<%= typeof description !== 'undefined' ? description : (settings.siteDescription || '') %>">
<meta name="twitter:image" content="<%= typeof image !== 'undefined' ? image : (settings.logoUrl || '/images/logo.svg') %>">
<meta name="theme-color" content="#050505">
<% if (typeof schema !== 'undefined' && Array.isArray(schema)) { schema.forEach(function(item){ %>
<script type="application/ld+json"><%- JSON.stringify(item).replace(/</g,'\\u003c') %></script>
<% }) } %>
