<section class="article">

  <span class="cat">
    INFORMASI TERBARU
  </span>

  <h1>
    <%= page.title %>
  </h1>

  <p class="lead">
    <%= page.description %>
  </p>

  <div class="content">

    <p>
      <%= page.body %>
    </p>

    <p>
      Nikmati akses informasi yang lebih cepat, ringan, dan nyaman melalui halaman yang telah disusun responsif untuk perangkat mobile maupun desktop dengan tampilan modern dan navigasi yang mudah digunakan.
    </p>

  </div>

  <form
    class="searchbox"
    action="/search"
    method="get"
  >

    <input
      name="q"
      value="<%= (page.keywords || [])[0] || '' %>"
      placeholder="Cari halaman atau informasi lainnya..."
      autocomplete="off"
    >

    <button>
      Cari
    </button>

  </form>

</section>
