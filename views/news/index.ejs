<section class="page-title">

  <span>UPDATE TERBARU</span>

  <h1>
    Berita Bola, Jadwal, dan Informasi Pilihan Hari Ini
  </h1>

  <p>
    Dapatkan berbagai informasi terbaru mulai dari jadwal pertandingan, kabar transfer, prediksi laga, hingga update olahraga populer yang disajikan ringkas, cepat, dan nyaman diakses dari semua perangkat.
  </p>

</section>

<section class="grid cards wide">

  <% articles.forEach(a=>{ %>

    <article class="card">

      <img
        src="<%= a.coverUrl %>"
        alt="<%= a.title %>"
        loading="lazy"
      >

      <div>

        <span class="cat">
          <%= a.category %>
        </span>

        <h2>
          <a href="/berita/<%= a.slug %>">
            <%= a.title %>
          </a>
        </h2>

        <p>
          <%= a.excerpt %>
        </p>

      </div>

    </article>

  <% }) %>

</section>
