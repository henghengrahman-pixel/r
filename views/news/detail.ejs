<article class="article">
  <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span>›</span><a href="/berita">Berita Bola</a><span>›</span><strong><%= article.title %></strong></nav>
  <span class="cat"><%= article.category || 'Berita Bola' %></span>
  <h1><%= article.title %></h1>
  <div class="meta"><span>Oleh <%= article.author || 'Redaksi OMTOGEL' %></span><span>•</span><time datetime="<%= article.publishedAt %>"><%= new Date(article.publishedAt || Date.now()).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) %></time></div>
  <img class="cover" src="<%= article.coverUrl || '/images/default-cover.svg' %>" alt="<%= article.title %>" loading="eager" width="1200" height="675" onerror="this.src='/images/default-cover.svg'">
  <div class="sharebar"><a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(canonical) %>" rel="nofollow noopener" target="_blank">Facebook</a><a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(canonical) %>&text=<%= encodeURIComponent(article.title) %>" rel="nofollow noopener" target="_blank">Twitter</a><a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' ' + canonical) %>" rel="nofollow noopener" target="_blank">WhatsApp</a></div>
  <div class="content"><%- article.content || '<p>Konten artikel sedang diperbarui oleh redaksi.</p>' %></div>
  <section class="internal-links"><h2>Topik Terkait OMTOGEL</h2><div class="chips"><a href="/search/omtogel">OMTOGEL</a><a href="/search/login-omtogel">Login OMTOGEL</a><a href="/search/link-alternatif-omtogel">Link Alternatif</a><a href="/search/livescore-omtogel">Livescore</a><a href="/search/prediksi-bola-omtogel">Prediksi Bola</a></div></section>
</article>
<section class="section narrow"><div class="section-head"><div><span>REKOMENDASI</span><h2>Artikel Terkait</h2></div><a class="view-all" href="/berita">Semua Berita</a></div><div class="grid cards related-grid"><% related.forEach(r => { %><article class="card"><a class="thumb" href="/berita/<%= r.slug %>"><img src="<%= r.coverUrl || '/images/default-cover.svg' %>" alt="<%= r.title %>" loading="lazy" width="640" height="360" onerror="this.src='/images/default-cover.svg'"></a><div class="card-body"><span class="cat"><%= r.category || 'Berita Bola' %></span><h3><a href="/berita/<%= r.slug %>"><%= r.title %></a></h3><p><%= r.excerpt || '' %></p></div></article><% }) %></div></section>
