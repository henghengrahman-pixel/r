<article class="article"><span class="cat"><%= article.category %></span><h1><%= article.title %></h1><div class="meta">Oleh <%= article.author %> • <%= new Date(article.publishedAt).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) %></div><img class="cover" src="<%= article.coverUrl %>" alt="<%= article.title %>"><div class="content"><%- article.content %></div></article><section class="section narrow"><h2>Artikel Terkait</h2><div class="related"><% related.forEach(r=>{ %><a href="/berita/<%= r.slug %>"><%= r.title %></a><% }) %></div></section>
