<article class="article">

  <nav class="breadcrumb">

    <a href="/">
      Home
    </a>

    <span>›</span>

    <a href="/berita">
      Berita Bola
    </a>

    <span>›</span>

    <strong>
      <%= article.title %>
    </strong>

  </nav>

  <span class="cat">
    <%= article.category %>
  </span>

  <h1>
    <%= article.title %>
  </h1>

  <div class="meta">

    <span>
      Oleh <%= article.author || 'OMTOGEL' %>
    </span>

    <span>•</span>

    <span>
      <%= new Date(article.publishedAt).toLocaleDateString(
        'id-ID',
        {
          day:'2-digit',
          month:'long',
          year:'numeric'
        }
      ) %>
    </span>

  </div>

  <img
    class="cover"
    src="<%= article.coverUrl %>"
    alt="<%= article.title %>"
    loading="lazy"
  >

  <div class="content">

    <p class="lead">

      OMTOGEL menghadirkan berita bola terbaru, live score realtime,
      prediksi pertandingan, jadwal bola malam ini, rumor transfer pemain,
      dan berbagai update olahraga dunia dengan tampilan modern yang ringan
      dan nyaman diakses melalui perangkat mobile.

    </p>

    <%- article.content %>

  </div>

  <section class="internal-links">

    <h3>
      Portal Terkait
    </h3>

    <div class="chips">

      <a href="/">
        OMTOGEL
      </a>

      <a href="/p/omtogel">
        Portal OMTOGEL
      </a>

      <a href="/search/live-score">
        Live Score
      </a>

      <a href="/search/prediksi-bola">
        Prediksi Bola
      </a>

      <a href="/search/jadwal-bola">
        Jadwal Bola
      </a>

      <a href="/search/berita-bola">
        Berita Bola
      </a>

    </div>

  </section>

</article>

<section class="section narrow">

  <div class="section-head">

    <div>

      <span>
        REKOMENDASI
      </span>

      <h2>
        Artikel dan Update Terkait
      </h2>

    </div>

    <a
      class="view-all"
      href="/berita"
    >
      Semua Berita
    </a>

  </div>

  <div class="grid cards related-grid">

    <% related.forEach(r => { %>

      <article class="card related-card">

        <a
          class="thumb"
          href="/berita/<%= r.slug %>"
        >

          <img
            src="<%= r.coverUrl %>"
            alt="<%= r.title %>"
            loading="lazy"
          >

        </a>

        <div class="card-body">

          <span class="cat">
            <%= r.category %>
          </span>

          <h3>

            <a href="/berita/<%= r.slug %>">
              <%= r.title %>
            </a>

          </h3>

          <p>
            <%= r.excerpt || '' %>
          </p>

          <div class="card-meta">

            <span>
              OMTOGEL
            </span>

            <a href="/berita/<%= r.slug %>">
              Baca →
            </a>

          </div>

        </div>

      </article>

    <% }) %>

  </div>

</section>

<section class="seo-bottom">

  <div class="seo-bottom-content">

    <h2>
      OMTOGEL Berita Bola dan Live Score Realtime
    </h2>

    <p>

      Ikuti update berita bola terbaru, jadwal pertandingan malam ini,
      live score realtime, prediksi pertandingan, transfer pemain,
      dan berbagai informasi sepak bola dunia hanya melalui portal resmi OMTOGEL.

    </p>

  </div>

</section>

<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"NewsArticle",
  "headline":"<%= article.title %>",
  "image":[
    "<%= article.coverUrl %>"
  ],
  "datePublished":"<%= article.publishedAt %>",
  "dateModified":"<%= article.updatedAt || article.publishedAt %>",
  "author":{
    "@type":"Person",
    "name":"<%= article.author || 'OMTOGEL' %>"
  },
  "publisher":{
    "@type":"Organization",
    "name":"OMTOGEL",
    "logo":{
      "@type":"ImageObject",
      "url":"<%= settings.logoUrl %>"
    }
  },
  "mainEntityOfPage":{
    "@type":"WebPage",
    "@id":"<%= baseUrl %>/berita/<%= article.slug %>"
  }
}
</script>
