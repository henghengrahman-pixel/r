<!doctype html>
<html lang="id">

<head>

  <meta charset="utf-8">

  <meta
    name="viewport"
    content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"
  >

  <title>
    <%= title || settings.siteName || 'OMTOGEL' %>
  </title>

  <meta
    name="description"
    content="<%= description || settings.siteDescription || 'OMTOGEL portal berita bola, live score realtime, prediksi bola, dan jadwal pertandingan terbaru.' %>"
  >

  <meta
    name="keywords"
    content="<%= keywords || 'omtogel, berita bola, live score, prediksi bola, jadwal bola, sbobet, portal bola' %>"
  >

  <meta
    name="robots"
    content="index,follow,max-image-preview:large"
  >

  <meta
    name="googlebot"
    content="index,follow,max-image-preview:large"
  >

  <meta
    property="og:type"
    content="website"
  >

  <meta
    property="og:site_name"
    content="<%= settings.siteName || 'OMTOGEL' %>"
  >

  <meta
    property="og:title"
    content="<%= title || settings.siteName || 'OMTOGEL' %>"
  >

  <meta
    property="og:description"
    content="<%= description || settings.siteDescription || 'OMTOGEL portal berita bola terbaru.' %>"
  >

  <meta
    property="og:url"
    content="<%= canonical || (baseUrl + currentPath) %>"
  >

  <meta
    property="og:image"
    content="<%= settings.logoUrl || '/images/logo.png' %>"
  >

  <meta
    name="twitter:card"
    content="summary_large_image"
  >

  <meta
    name="twitter:title"
    content="<%= title || settings.siteName || 'OMTOGEL' %>"
  >

  <meta
    name="twitter:description"
    content="<%= description || settings.siteDescription || 'OMTOGEL portal berita bola terbaru.' %>"
  >

  <meta
    name="twitter:image"
    content="<%= settings.logoUrl || '/images/logo.png' %>"
  >

  <link
    rel="canonical"
    href="<%= canonical || (baseUrl + currentPath) %>"
  >

  <link
    rel="icon"
    href="<%= settings.faviconUrl || '/favicon.ico' %>"
  >

  <link
    rel="apple-touch-icon"
    href="<%= settings.logoUrl || '/images/logo.png' %>"
  >

  <link
    rel="stylesheet"
    href="/css/style.css"
  >

  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"Organization",
    "name":"OMTOGEL",
    "url":"<%= baseUrl %>",
    "logo":"<%= settings.logoUrl || '/images/logo.png' %>"
  }
  </script>

  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"WebSite",
    "name":"OMTOGEL",
    "url":"<%= baseUrl %>",
    "potentialAction":{
      "@type":"SearchAction",
      "target":"<%= baseUrl %>/search?q={search_term_string}",
      "query-input":"required name=search_term_string"
    }
  }
  </script>

  <%- include('../partials/head') %>

</head>

<body>

  <div class="page-bg"></div>

  <%- include('../partials/header') %>

  <main class="site-main">

    <section class="seo-top">

      <h1>
        <%= settings.siteName || 'OMTOGEL' %>
      </h1>

      <div class="seo-keywords">

        <h2>Berita Bola Hari Ini</h2>

        <h2>Live Score Realtime</h2>

        <h2>Prediksi Bola Terbaru</h2>

        <h2>Jadwal Bola Malam Ini</h2>

      </div>

    </section>

    <%- body %>

  </main>

  <%- include('../partials/footer') %>

  <script src="/js/app.js"></script>

</body>

</html>
